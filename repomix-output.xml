'use client';

import { useState } from 'react';
import { useLanguage } from '../contexts/LanguageContext';
import timelineData from '../content/timeline.json';
import { Calendar } from 'lucide-react';

export default function Timeline() {
  const { t } = useLanguage();
  const [activeItem, setActiveItem] = useState<string | null>(null);

  const timelineItems = timelineData.items.filter(item => item.visible).sort((a, b) => a.order - b.order);

  return (
    <section
      id="timeline"
      aria-labelledby="timeline-title"
      className="py-20 bg-neutral-900/50"
    >
      <div className="max-w-6xl mx-auto px-4">
        <div className="text-center mb-16">
          <h2
            id="timeline-title"
            className="text-4xl md:text-5xl font-bold text-amber-100 mb-4"
          >
            {t(timelineData.title)}
          </h2>
          <div className="w-24 h-1 bg-gradient-to-r from-amber-500 to-amber-400 mx-auto"></div>
        </div>

        <div className="relative">
          <div className="absolute left-1/2 transform -translate-x-1/2 h-full w-0.5 bg-amber-500/30"></div>

          <div className="space-y-12">
            {timelineItems.map((item, index) => (
              <div
                key={item.id}
                className={`relative flex items-center ${
                  index % 2 === 0 ? 'flex-row' : 'flex-row-reverse'
                }`}
              >
                <div className={`w-1/2 ${index % 2 === 0 ? 'pr-12 text-right' : 'pl-12 text-left'}`}>
                  <div
                    className={`bg-amber-500/10 backdrop-blur-sm border border-amber-500/20 rounded-2xl p-6 hover:bg-amber-500/20 transition-all duration-300 cursor-pointer ${
                      activeItem === item.id ? 'ring-2 ring-amber-500' : ''
                    }`}
                    onClick={() => setActiveItem(activeItem === item.id ? null : item.id)}
                    onKeyDown={(e) => {
                      if (e.key === 'Enter' || e.key === ' ') {
                        setActiveItem(activeItem === item.id ? null : item.id);
                      }
                    }}
                    tabIndex={0}
                    role="button"
                    aria-expanded={activeItem === item.id}
                  >
                    <div className="flex items-center gap-3 mb-3 justify-end">
                      <Calendar className="w-5 h-5 text-amber-400" />
                      <span className="text-amber-400 font-bold text-lg">{item.year}</span>
                    </div>
                    <h3 className="text-xl font-bold text-amber-100 mb-2">
                      {t(item.content.title)}
                    </h3>
                    <p className="text-amber-100/70 leading-relaxed">
                      {t(item.content.description)}
                    </p>
                  </div>
                </div>

                <div className="absolute left-1/2 transform -translate-x-1/2 w-4 h-4 bg-amber-500 rounded-full border-4 border-neutral-900 z-10"></div>

                <div className="w-1/2"></div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  );
}
