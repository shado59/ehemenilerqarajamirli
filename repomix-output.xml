                  </p>
                  <p className="text-amber-100">{t(selectedArtifact.content.location)}</p>
                </div>
              </div>

              <div className="border-t border-amber-500/20 pt-4">
                <p className="text-amber-100/80 leading-relaxed">
                  {t(selectedArtifact.content.description)}
                </p>
              </div>
            </div>
          </div>
        </div>
      )}
    </section>
  );
}
