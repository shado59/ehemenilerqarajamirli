import { NextRequest, NextResponse } from 'next/server';
import fs from 'fs/promises';
import path from 'path';

// Validate path to avoid path traversal issues.
function getSafePath(relativePath: string) {
  const projectRoot = process.cwd();
  // Resolve absolute path
  const resolvedPath = path.resolve(projectRoot, relativePath);
  if (!resolvedPath.startsWith(projectRoot)) {
    throw new Error('Access denied: Path traversal detected');
  }
  return resolvedPath;
}

export async function GET(request: NextRequest) {
  const { searchParams } = new URL(request.url);
  const relativePath = searchParams.get('path');

  if (!relativePath) {
    return NextResponse.json({ error: 'Missing path' }, { status: 400 });
  }

  try {
    const absolutePath = getSafePath(relativePath);
    const content = await fs.readFile(absolutePath, 'utf-8');
    return NextResponse.json({ content });
  } catch (error: any) {
    if (error.code === 'ENOENT') {
      return NextResponse.json({ error: 'File not found' }, { status: 404 });
    }
    return NextResponse.json({ error: error.message || 'Internal server error' }, { status: 500 });
  }
}

export async function POST(request: NextRequest) {
  try {
    const body = await request.json();
    const { action, path: relativePath, content } = body;

    if (!action || !relativePath) {
      return NextResponse.json({ error: 'Missing required fields' }, { status: 400 });
    }

    const absolutePath = getSafePath(relativePath);

    if (action === 'update') {
      // Ensure parent directory exists
      await fs.mkdir(path.dirname(absolutePath), { recursive: true });
      await fs.writeFile(absolutePath, content, 'utf-8');
      return NextResponse.json({ success: true });
    } else if (action === 'upload') {
      // content is base64 string
      await fs.mkdir(path.dirname(absolutePath), { recursive: true });
      const buffer = Buffer.from(content, 'base64');
      await fs.writeFile(absolutePath, buffer);
      return NextResponse.json({ success: true });
    } else if (action === 'delete') {
      await fs.unlink(absolutePath);
      return NextResponse.json({ success: true });
    } else if (action === 'list') {
      try {
        const files = await fs.readdir(absolutePath);
        // resolve full relative paths of files
        const filePaths = files.map(file => path.join(relativePath, file).replace(/\\/g, '/'));
        return NextResponse.json({ files: filePaths });
      } catch (error: any) {
        if (error.code === 'ENOENT') {
          return NextResponse.json({ files: [] });
        }
        throw error;
      }
    } else {
      return NextResponse.json({ error: 'Invalid action' }, { status: 400 });
    }
  } catch (error: any) {
    return NextResponse.json({ error: error.message || 'Internal server error' }, { status: 500 });
  }
}
</file>

<file path="src/app/api/admin/login/route.ts">
import { NextRequest, NextResponse } from 'next/server';
import { GitHubService } from '@/lib/github-service';
import { createSession } from '@/lib/session';

export async function POST(request: NextRequest) {
  try {
    const body = await request.json();
    const { username, repository, token, branch } = body;

    if (!username || !repository || !token) {
      return NextResponse.json(
        { error: 'Missing required fields' },
        { status: 400 }
      );
    }

    const githubService = new GitHubService({
      username,
      repository,
      token,
      branch: branch || 'main',
    });

    // Test connection
    const connected = await githubService.testConnection();
    if (!connected) {
      return NextResponse.json(
        { error: 'Failed to connect to GitHub repository' },
        { status: 401 }
      );
    }

    // Validate branch
    const branchValid = await githubService.validateBranch();
    if (!branchValid) {
      return NextResponse.json(
        { error: 'Branch not found' },
        { status: 400 }
      );
    }

    // Create session
    createSession({
      username,
      repository,
      token,
      branch: branch || 'main',
      createdAt: Date.now(),
    });

    return NextResponse.json({ success: true });
  } catch (error) {
    console.error('Login error:', error);
    return NextResponse.json(
      { error: 'Internal server error' },
      { status: 500 }
    );
  }
}
</file>

